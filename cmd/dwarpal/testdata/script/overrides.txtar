# gate-diff-budget: files under an override glob use the override budget, so a
# diff that is large only because of generated files still passes.
exec git init
exec git add .
exec dwarpal check
stdout 'no findings'

-- .dwarpal.yml --
version: 1
gates:
  diff_budget:
    max_lines: 20
    overrides:
      - paths: ["generated/**"]
        max_lines: 10000
