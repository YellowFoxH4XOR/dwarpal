# gate-provenance: apply_gates_to defaults to ALL-COMMITS — a human commit on a
# normal branch is gated like any other. Teams exempt humans by opting into
# agent-only explicitly (second half).
exec git init
exec git branch -m main
exec git add .
! exec dwarpal check
stdout 'exceeds'

# Opt out: agent-only exempts this human commit from the content gates.
cp agent_only.yml .dwarpal.yml
exec git add .dwarpal.yml
exec dwarpal check
stdout 'no findings'

-- .dwarpal.yml --
version: 1
gates:
  diff_budget:
    max_lines: 3
-- agent_only.yml --
version: 1
provenance:
  apply_gates_to: agent-only
gates:
  diff_budget:
    max_lines: 3
-- big.txt --
a
b
c
d
e
