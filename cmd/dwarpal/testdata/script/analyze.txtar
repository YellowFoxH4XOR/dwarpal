# analyze: deterministic repo facts for agent-authored config. No network, no
# config/source writes (only the gitignored cache). Human + --json output.
exec git init
exec git add .
exec git commit -m 'seed'

# human output: languages, a suggested budget, and the detected Go conventions
exec dwarpal analyze
stdout 'Languages: \[go\]'
stdout 'Suggested diff_budget.max_lines:'
stdout '3 functions'

# thin history (<10 commits) must honestly fall back to the documented default
stdout 'default'
# and must NOT print a bogus all-zero distribution in that fallback
! stdout 'median 0, p75 0'

# --json: a single machine-readable document with the measured facts
exec dwarpal analyze --json
stdout '"languages"'
stdout '"diff_budget"'
stdout '"max_lines"'
stdout '"funcs": 3'

# analyze must not create or mutate the config
! exists .dwarpal.yml

# init --learn prints the analysis, THEN writes the starter config
exec dwarpal init --learn
stdout 'Suggested diff_budget.max_lines:'
exists .dwarpal.yml

-- main.go --
package main

import "fmt"

func run() error {
	if err := step(); err != nil {
		return fmt.Errorf("run: %w", err)
	}
	return nil
}

func step() error {
	return fmt.Errorf("step: %w", errBoom)
}

var errBoom = fmt.Errorf("boom")

func main() { _ = run() }
