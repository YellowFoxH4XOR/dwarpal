# A configured-but-missing detector must FAIL the ratchet (exit 2), never pass
# as zero — a ratchet you could not run is not a ratchet that passed. This is
# the anti-silent-pass invariant (CLAUDE.md Rule 12). `vulture` is not installed
# in the test environment, so --check must refuse rather than certify.
exec git init
exec git add .dwarpal.yml
exec git commit -m init

! exec dwarpal census --check
stderr 'not installed'

# Report mode still runs, marking the detector as skipped (informational).
exec dwarpal census
stdout 'SKIPPED'

-- .dwarpal.yml --
version: 1
census:
  detectors: [vulture]
