#!/bin/sh
# Managed by Dwarpal (https://github.com/YellowFoxH4XOR/dwarpal). Do not edit.
if ! command -v dwarpal >/dev/null 2>&1; then
  echo "dwarpal: binary not found on PATH." >&2
  echo "  Fix your install, or remove the hooks with: dwarpal hook uninstall" >&2
  echo "  (or manually: git config --unset core.hooksPath)" >&2
  exit 1
fi

# One-shot bypass: if 'dwarpal bypass --reason ...' armed a token, consume it —
# skip the gates for THIS commit only, still writing the push marker below.
# The bypass itself was already audited (.dwarpal/bypass.log + git note).
token="$(git rev-parse --git-dir)/dwarpal-bypass-once"
if [ -f "$token" ]; then
  rm -f "$token"
  echo "dwarpal: one-shot bypass consumed — gates skipped for this commit." >&2
else
  dwarpal check || exit $?
fi

# Record a success marker keyed to the staged tree so the pre-push hook can
# tell a gated commit from one made with --no-verify.
marker="$(git rev-parse --git-dir)/dwarpal-ok"
tree="$(git write-tree)"
grep -qxF "$tree" "$marker" 2>/dev/null || echo "$tree" >> "$marker"
exit 0
